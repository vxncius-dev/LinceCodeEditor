{
  "schema": 3,
  "app": "Lince Code Editor",
  "releaseTag": "v1.0.0",
  "defaultReleaseTag": "v1.0.0",
  "assetNamePattern": "lince-{type}-{key}-{abi}.zip",
  "defaultAbiPriority": [
    "arm64-v8a",
    "x86_64",
    "armeabi-v7a",
    "x86"
  ],
  "sections": {
    "agents": {
      "title": "Agentes",
      "subtitle": "Modelos externos para assistência no código."
    },
    "tools": {
      "title": "Ferramentas",
      "subtitle": "Utilitários de terminal, rede, Git e Android."
    },
    "stacks": {
      "title": "Linguagens",
      "subtitle": "Runtimes e compiladores para executar projetos."
    }
  },
  "agents": [
    {
      "key": "claude",
      "name": "Claude",
      "provider": "Anthropic",
      "status": "development",
      "installable": false,
      "configurable": true,
      "auth": "api_key",
      "iconResName": "ic_agent_claude",
      "fallbackIcon": "CL",
      "description": "Assistência e revisão de código."
    },
    {
      "key": "codex",
      "name": "Codex",
      "provider": "OpenAI",
      "status": "development",
      "installable": false,
      "configurable": true,
      "auth": "api_key",
      "iconResName": "ic_agent_codex",
      "fallbackIcon": "AI",
      "description": "Agente para código e automações."
    },
    {
  "key": "copilot",
  "name": "Copilot",
  "provider": "GitHub",
  "status": "development",
  "installable": false,
  "configurable": true,
  "auth": "github_oauth",
  "iconResName": "ic_agent_copilot",
  "fallbackIcon": "CP",
  "description": "Assistência de código integrada ao GitHub Copilot."
    },
    {
      "key": "gemini",
      "name": "Gemini",
      "provider": "Google",
      "status": "development",
      "installable": false,
      "configurable": true,
      "auth": "api_key",
      "iconResName": "ic_agent_gemini",
      "fallbackIcon": "GM",
      "description": "Modelo externo para assistência."
    },
    {
      "key": "deepseek",
      "name": "DeepSeek",
      "provider": "DeepSeek",
      "status": "development",
      "installable": false,
      "configurable": true,
      "auth": "api_key",
      "iconResName": "ic_agent_deepseek",
      "fallbackIcon": "DS",
      "description": "Modelo externo para código."
    },
    {
  "key": "manus",
  "name": "Manus",
  "provider": "Manus",
  "status": "development",
  "installable": false,
  "configurable": true,
  "auth": "api_key",
  "iconResName": "ic_agent_manus",
  "fallbackIcon": "MS",
  "description": "Agente autônomo para executar tarefas, automações e entregas completas."
    },
    {
  "key": "ollama",
  "name": "Ollama",
  "provider": "Ollama",
  "status": "development",
  "installable": false,
  "configurable": true,
  "auth": "local_endpoint",
  "iconResName": "ic_agent_ollama",
  "fallbackIcon": "OL",
  "baseUrl": "http://127.0.0.1:11434/api",
  "description": "Provider local para modelos abertos via API compatível com Ollama."
    }
  ],
  "tools": [
    {
      "key": "git",
      "type": "tool",
      "name": "Git",
      "version": "2.54.0",
      "status": "stable",
      "installable": true,
      "releaseTag": "v1.0.0",
      "iconResName": "icons8_git_128",
      "fallbackIcon": "Git",
      "assetPrefix": "lince-tool-git",
      "commands": [
        "git"
      ],
      "requiredFiles": [
        "bin/git"
      ],
      "description": "Controle de versão local e remoto."
    },
    {
      "key": "github",
      "type": "tool",
      "name": "GitHub CLI",
      "version": "2.92.0",
      "status": "stable",
      "installable": true,
      "releaseTag": "v1.0.0",
      "iconResName": "ic_lang_github",
      "fallbackIcon": "GH",
      "assetPrefix": "lince-tool-github",
      "commands": [
        "gh"
      ],
      "requiredFiles": [
        "bin/gh"
      ],
      "auth": "github_device_flow",
      "description": "gh auth login, repositórios e integração com GitHub."
    },
    {
      "key": "curl",
      "type": "tool",
      "name": "Curl",
      "version": "8.20.0",
      "status": "stable",
      "installable": true,
      "releaseTag": "v2.0.0",
      "iconResName": "ic_lang_curl",
      "fallbackIcon": "curl",
      "assetPrefix": "lince-tool-curl",
      "commands": [
        "curl"
      ],
      "requiredFiles": [
        "bin/curl",
        "etc/tls/cert.pem"
      ],
      "env": {
        "SSL_CERT_FILE": "{runtime}/etc/tls/cert.pem",
        "CURL_CA_BUNDLE": "{runtime}/etc/tls/cert.pem"
      },
      "description": "Cliente HTTP para terminal com suporte a HTTPS."
    },
    {
      "key": "android_tools",
      "type": "tool",
      "name": "Android Tools",
      "version": "build-tools",
      "status": "development",
      "installable": false,
      "iconResName": "ic_lang_android_tools",
      "fallbackIcon": "ADT",
      "assetPrefix": "lince-tool-android-tools",
      "commands": [
        "aapt2",
        "zipalign",
        "apksigner"
      ],
      "description": "Ferramentas auxiliares para builds Android."
    }
  ],
  "stacks": [
    {
      "key": "python",
      "type": "stack",
      "name": "Python",
      "version": "3.13.13",
      "status": "stable",
      "installable": true,
      "releaseTag": "v1.0.0",
      "iconResName": "ic_lang_python",
      "fallbackIcon": "Py",
      "assetPrefix": "lince-stack-python",
      "commands": [
        "python",
        "python3",
        "pip",
        "pip3"
      ],
      "requiredFiles": [
        "bin/python"
      ],
      "env": {
        "PYTHONHOME": "{runtime}",
        "PYTHONPATH": "{runtime}/lib/python3.13/site-packages",
        "PIP_CACHE_DIR": "{appCache}/pip",
        "PYTHONNOUSERSITE": "1"
      },
      "description": "Scripts Python e pip."
    },
    {
      "key": "node",
      "type": "stack",
      "name": "Node.js",
      "version": "v26.2.0",
      "status": "stable",
      "installable": true,
      "releaseTag": "v3.0.0",
      "iconResName": "ic_lang_node",
      "fallbackIcon": "JS",
      "assetPrefix": "lince-stack-node",
      "commands": [
        "node",
        "npm",
        "npx"
      ],
      "requiredFiles": [
        "bin/node",
        "bin/npm",
        "bin/npx",
        "lib/node_modules/npm/bin/npm-cli.js",
        "lib/node_modules/npm/bin/npx-cli.js"
      ],
      "env": {
        "NODE_PATH": "{runtime}/lib/node_modules",
        "NPM_CONFIG_PREFIX": "{runtime}",
        "NPM_CONFIG_CACHE": "{appCache}/npm"
      },
      "description": "Node, npm e npx."
    },
    {
      "key": "go",
      "type": "stack",
      "name": "Go",
      "version": "1.26.3",
      "status": "stable",
      "installable": true,
      "releaseTag": "v2.0.0",
      "iconResName": "ic_lang_go",
      "fallbackIcon": "Go",
      "assetPrefix": "lince-stack-go",
      "commands": [
        "go",
        "gofmt"
      ],
      "requiredFiles": [
        "bin/go",
        "bin/gofmt",
        "lib/go"
      ],
      "env": {
        "GOROOT": "{runtime}/lib/go",
        "GOPATH": "{appFiles}/go",
        "GOCACHE": "{appCache}/go-build",
        "GOMODCACHE": "{appFiles}/go/pkg/mod"
      },
      "description": "Go toolchain."
    },
    {
      "key": "ruby",
      "type": "stack",
      "name": "Ruby",
      "version": "3.4.1",
