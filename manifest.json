{
  "schema": 2,
  "app": "Lince Code Editor",
  "releaseTag": "latest",
  "assetNamePattern": "lince-{type}-{key}-{abi}.zip",
  "defaultAbiPriority": [
    "arm64-v8a",
    "x86_64",
    "armeabi-v7a",
    "x86"
  ],
  "sections": {
    "agents": {
      "title": "Agentes",
      "subtitle": "Modelos externos para assistência no código."
    },
    "tools": {
      "title": "Ferramentas",
      "subtitle": "Utilitários de terminal, rede, Git e Android."
    },
    "stacks": {
      "title": "Linguagens",
      "subtitle": "Runtimes e compiladores para executar projetos."
    }
  },
  "agents": [
    {
      "key": "claude",
      "name": "Claude",
      "provider": "Anthropic",
      "status": "development",
      "installable": false,
      "configurable": true,
      "auth": "api_key",
      "iconResName": "ic_agent_claude",
      "fallbackIcon": "CL",
      "description": "Assistência e revisão de código."
    },
    {
      "key": "codex",
      "name": "Codex",
      "provider": "OpenAI",
      "status": "development",
      "installable": false,
      "configurable": true,
      "auth": "api_key",
      "iconResName": "ic_agent_codex",
      "fallbackIcon": "AI",
      "description": "Agente para código e automações."
    },
    {
      "key": "gemini",
      "name": "Gemini",
      "provider": "Google",
      "status": "development",
      "installable": false,
      "configurable": true,
      "auth": "api_key",
      "iconResName": "ic_agent_gemini",
      "fallbackIcon": "GM",
      "description": "Modelo externo para assistência."
    },
    {
      "key": "deepseek",
      "name": "DeepSeek",
      "provider": "DeepSeek",
      "status": "development",
      "installable": false,
      "configurable": true,
      "auth": "api_key",
      "iconResName": "ic_agent_deepseek",
      "fallbackIcon": "DS",
      "description": "Modelo externo para código."
    }
  ],
  "tools": [
    {
      "key": "git",
      "name": "Git",
      "version": "2.x",
      "status": "development",
      "installable": false,
      "iconResName": "icons8_git_128",
      "fallbackIcon": "Git",
      "assetPrefix": "lince-tool-git",
      "commands": ["git"],
      "description": "Controle de versão local e remoto."
    },
    {
      "key": "github",
      "name": "GitHub",
      "version": "CLI",
      "status": "development",
      "installable": false,
      "iconResName": "ic_lang_github",
      "fallbackIcon": "GH",
      "assetPrefix": "lince-tool-github",
      "commands": ["gh"],
      "description": "Integração com GitHub."
    },
    {
      "key": "curl",
      "name": "Curl",
      "version": "8.x",
      "status": "development",
      "installable": false,
      "iconResName": "ic_lang_curl",
      "fallbackIcon": "curl",
      "assetPrefix": "lince-tool-curl",
      "commands": ["curl"],
      "description": "Cliente HTTP para terminal."
    },
    {
      "key": "android_tools",
      "name": "Android Tools",
      "version": "build-tools",
      "status": "development",
      "installable": false,
      "iconResName": "ic_lang_android_tools",
      "fallbackIcon": "ADT",
      "assetPrefix": "lince-tool-android-tools",
      "commands": ["aapt2", "zipalign", "apksigner"],
      "description": "Ferramentas auxiliares para builds Android."
    }
  ],
  "stacks": [
    {
      "key": "python",
      "name": "Python",
      "version": "3.12.x",
      "status": "development",
      "installable": false,
      "iconResName": "ic_lang_python",
      "fallbackIcon": "Py",
      "assetPrefix": "lince-stack-python",
      "commands": ["python", "python3", "pip", "pip3"],
      "description": "Scripts Python e pip."
    },
    {
      "key": "node",
      "name": "Node.js",
      "version": "22.x LTS",
      "status": "development",
      "installable": false,
      "iconResName": "ic_lang_node",
      "fallbackIcon": "JS",
      "assetPrefix": "lince-stack-node",
      "commands": ["node", "npm", "npx"],
      "description": "Node, npm e npx."
    },
    {
      "key": "java",
      "name": "Java",
      "version": "JDK 21 LTS",
      "status": "development",
      "installable": false,
      "iconResName": "ic_lang_java",
      "fallbackIcon": "Java",
      "assetPrefix": "lince-stack-java",
      "commands": ["java", "javac"],
