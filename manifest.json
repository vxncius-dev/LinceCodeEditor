{
  "schema": 3,
  "app": "Lince Code Editor",
  "releaseTag": "v1.0.0",
  "defaultReleaseTag": "v1.0.0",
  "assetNamePattern": "lince-{type}-{key}-{abi}.zip",
  "defaultAbiPriority": [
    "arm64-v8a",
    "x86_64",
    "armeabi-v7a",
    "x86"
  ],
  "sections": {
    "agents": {
      "title": "Agentes",
      "subtitle": "Modelos externos para assistência no código."
    },
    "tools": {
      "title": "Ferramentas",
      "subtitle": "Utilitários de terminal, rede, Git e Android."
    },
    "stacks": {
      "title": "Linguagens",
      "subtitle": "Runtimes e compiladores para executar projetos."
    }
  },
  "agents": [
    {
      "key": "claude",
      "name": "Claude",
      "provider": "Anthropic",
      "status": "development",
      "installable": false,
      "configurable": true,
      "auth": "api_key",
      "iconResName": "ic_agent_claude",
      "fallbackIcon": "CL",
      "description": "Assistência e revisão de código."
    },
    {
      "key": "codex",
      "name": "Codex",
      "provider": "OpenAI",
      "status": "development",
      "installable": false,
      "configurable": true,
      "auth": "api_key",
      "iconResName": "ic_agent_codex",
      "fallbackIcon": "CX",
      "description": "Agente de código para geração, edição e revisão."
    },
    {
      "key": "gemini",
      "name": "Gemini",
      "provider": "Google",
      "status": "development",
      "installable": false,
      "configurable": true,
      "auth": "api_key",
      "iconResName": "ic_agent_gemini",
      "fallbackIcon": "GM",
      "description": "Assistência multimodal e análise de código."
    }
  ],
  "tools": [
    {
      "key": "git",
      "type": "tool",
      "name": "Git",
      "version": "2.54.0",
      "status": "stable",
      "installable": true,
      "releaseTag": "v1.0.0",
      "assetPrefix": "lince-tool-git",
      "commands": [
        "git"
      ],
      "requiredFiles": [
        "bin/git"
      ],
      "description": "Controle de versão local e remoto."
    },
    {
      "key": "github",
      "type": "tool",
      "name": "GitHub CLI",
      "version": "2.x",
      "status": "stable",
      "installable": true,
      "releaseTag": "v1.0.0",
      "assetPrefix": "lince-tool-github",
      "commands": [
        "gh"
      ],
      "requiredFiles": [
        "bin/gh"
      ],
      "auth": "github_device_flow",
      "description": "CLI oficial do GitHub para login, repositórios, releases e workflows."
    },
    {
      "key": "curl",
      "type": "tool",
      "name": "Curl",
      "version": "8.x",
      "status": "stable",
      "installable": true,
      "releaseTag": "v0.2.0",
      "assetPrefix": "lince-tool-curl",
      "commands": [
        "curl"
      ],
      "requiredFiles": [
        "bin/curl",
        "etc/tls/cert.pem"
      ],
      "env": {
        "SSL_CERT_FILE": "{runtime}/etc/tls/cert.pem",
        "CURL_CA_BUNDLE": "{runtime}/etc/tls/cert.pem"
      },
      "description": "Cliente HTTP para terminal com suporte a HTTPS."
    }
  ],
  "stacks": [
    {
      "key": "python",
      "type": "stack",
      "name": "Python",
      "version": "3.13",
      "status": "stable",
      "installable": true,
      "releaseTag": "v1.0.0",
      "assetPrefix": "lince-stack-python",
      "commands": [
        "python",
        "python3",
        "pip",
        "pip3"
      ],
      "requiredFiles": [
        "bin/python"
      ],
      "env": {
        "PYTHONHOME": "{runtime}",
        "PYTHONPATH": "{runtime}/lib/python3.13/site-packages",
        "PIP_CACHE_DIR": "{appCache}/pip",
        "PYTHONNOUSERSITE": "1"
      },
      "description": "Runtime Python com pip para scripts e automações."
    },
    {
      "key": "node",
      "type": "stack",
      "name": "Node.js",
      "version": "22.x",
      "status": "stable",
      "installable": true,
      "releaseTag": "v0.2.0",
      "assetPrefix": "lince-stack-node",
      "commands": [
        "node",
        "npm",
        "npx"
      ],
      "requiredFiles": [
        "bin/node",
        "bin/npm",
        "bin/npx",
        "lib/node_modules/npm/bin/npm-cli.js",
        "lib/node_modules/npm/bin/npx-cli.js"
      ],
      "env": {
        "NODE_PATH": "{runtime}/lib/node_modules",
        "NPM_CONFIG_PREFIX": "{runtime}",
        "NPM_CONFIG_CACHE": "{appCache}/npm"
      },
      "description": "Runtime JavaScript com npm e npx."
    },
    {
      "key": "go",
      "type": "stack",
      "name": "Go",
      "version": "1.x",
      "status": "stable",
      "installable": true,
      "releaseTag": "v0.2.0",
      "assetPrefix": "lince-stack-go",
      "commands": [
        "go",
        "gofmt"
      ],
      "requiredFiles": [
        "bin/go",
        "bin/gofmt",
        "lib/go"
      ],
      "env": {
        "GOROOT": "{runtime}/lib/go",
        "GOPATH": "{appFiles}/go",
        "GOCACHE": "{appCache}/go-build",
        "GOMODCACHE": "{appFiles}/go/pkg/mod"
      },
      "description": "Go toolchain para compilar e executar projetos Go."
    },
    {
      "key": "lua",
      "type": "stack",
      "name": "Lua",
      "version": "5.4",
      "status": "stable",
      "installable": true,
      "releaseTag": "v1.0.0",
      "assetPrefix": "lince-stack-lua",
      "commands": [
        "lua",
        "lua5.4"
      ],
      "requiredFiles": [
        "bin/lua"
      ],
      "description": "Runtime Lua leve para scripts."
    },
    {
      "key": "ruby",
      "type": "stack",
      "name": "Ruby",
      "version": "3.x",
      "status": "stable",
      "installable": true,
      "releaseTag": "v1.0.0",
      "assetPrefix": "lince-stack-ruby",
      "commands": [
        "ruby",
        "gem"
      ],
      "requiredFiles": [
        "bin/ruby"
      ],
      "env": {
        "GEM_HOME": "{appFiles}/gems",
        "GEM_PATH": "{appFiles}/gems"
      },
      "description": "Runtime Ruby com suporte a scripts e gems."
    }
  ]
}
