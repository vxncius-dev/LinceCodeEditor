      ],
      "requiredFiles": [
        "bin/ruby"
      ],
      "env": {
        "GEM_HOME": "{appFiles}/gems",
        "GEM_PATH": "{appFiles}/gems"
      },
      "description": "Runtime Ruby."
    },
    {
      "key": "lua",
